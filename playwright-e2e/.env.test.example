# ============================================================
# TAMtracker QA — Environment Configuration
# ============================================================
# Copy this file to .env.test and fill in your QA values.
# NEVER commit .env.test with real credentials to Git.
# ============================================================

# App URLs
BASE_URL=https://tamtracker.io
USER_APP_URL=https://tamtracker.io
AGENCY_APP_URL=https://agency.tamtracker.io
API_BASE_URL=https://tamtracker.io

# QA Test User — User App
QA_USER_EMAIL=qa-user@example.com
QA_USER_PASSWORD=TestPassword@123

# QA Test User — Agency App
QA_AGENCY_EMAIL=qa-agency@example.com
QA_AGENCY_PASSWORD=TestPassword@123

# API auth token (from QA login session)
QA_API_TOKEN=your_qa_bearer_token_here

# Test data IDs (from your QA/staging environment)
QA_EVENT_ID=12345
QA_ACCOUNT_ID=99999
